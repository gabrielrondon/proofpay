# ProofPay configuration

# HTTP bind address
PROOFPAY_BIND=0.0.0.0:3402

# Stellar network (stellar:testnet or stellar:pubnet)
STELLAR_NETWORK=stellar:testnet

# Stellar account that receives micropayments for gated access
STELLAR_RECIPIENT=GDQOE23CFSUMSVQK4Y5JHPPYK73VYCNHZHA7ENKCV37P6SUEO6XQBKPP

# Payment required per access, in stroops (1 XLM = 10_000_000 stroops)
PAYMENT_AMOUNT_STROOPS=1000000

# Asset code ("native" for XLM)
PAYMENT_ASSET=native

# Human-readable description returned in the 402 response
ACCESS_DESCRIPTION=Access to ZK-verified agent resource

# x402 facilitator endpoint (verifies and settles Stellar payments)
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet

# Set to "true" to bypass the facilitator and accept any X-Payment header.
# Useful for local demos and for the bundled example agent.
X402_MOCK=false
